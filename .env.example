# DeepSeek API 配置
# 请到 https://platform.deepseek.com/api_keys 获取你的 API Key
DEEPSEEK_API_KEY=你的API密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 可选: deepseek-v4-pro (更强大，但成本更高)
# DEEPSEEK_MODEL=deepseek-v4-pro

# 应用配置
MAX_FILE_SIZE_MB=50
MAX_ROWS_PREVIEW=100
CHUNK_SIZE=10000
API_TIMEOUT=60
API_MAX_RETRIES=3
